# Supabase (required for dev server)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (required for paid flows)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Mux (required for video upload + playback)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_SIGNING_KEY_ID=
MUX_SIGNING_KEY_PRIVATE=

# Base URL for redirects
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Playwright E2E (optional — tests skip gracefully if not set)
E2E_BASE_URL=
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
E2E_READY_LESSON_URL=

# Observability — Sentry (https://sentry.io)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=

# Rate limiter — Upstash Redis (https://upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
